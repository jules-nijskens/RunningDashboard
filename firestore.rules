rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY: Allow any authenticated user while we fix specific owner rules
    // The UI is already restricted to jls.nijskens@gmail.com in AuthGuard.tsx
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
